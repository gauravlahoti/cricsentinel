    {
      "eval_id": "multi_anomaly_triage",
      "description": "Two simultaneous concerns — agent should triage and prioritise",
      "tags": ["quality", "triage", "prioritisation"],
      "request": {
        "query": "We have both a Gate E bottleneck forming AND a CAM_09 bag anomaly. Which do we address first?",
        "matchState": {
          "id": "nm-2026-rcb-mi",
          "teams": { "home": "RCB", "away": "MI" },
          "venue": "Narendra Modi Stadium",
          "format": "T20",
          "innings": 1,
          "status": "innings_break",
          "phase": "innings_break",
          "score": { "runs": 186, "wickets": 6, "overs": "20.0" },
          "data_complete": true,
          "updated_at": "2026-05-23T17:00:00Z"
        },
        "opsPosture": {
          "level": "amber",
          "driver": "Multiple simultaneous alerts",
          "since": "2026-05-23T16:59:00Z",
          "match_phase": "innings_break"
        },
        "currentAnomaly": {
          "id": "anom-003",
          "camera": "CAM_09",
          "section": "SEC_205",
          "kind": "UNATTENDED",
          "bbox": [300, 200, 60, 45],
          "confidence": 0.88,
          "ts": "2026-05-23T16:58:00Z"
        },
        "weather": "CLEAR · 28°C"
      },
      "criteria": {
        "response_relevance": {
          "rubric": "The response provides a clear triage decision — identifying which issue to address first and why, rather than treating both as equally urgent without guidance.",
          "threshold": 0.85
        },
        "operational_soundness": {
          "rubric": "The prioritisation decision is operationally sound — the bag anomaly (security risk) should typically take priority over a flow bottleneck, unless the bottleneck creates an immediate crush risk.",
          "threshold": 0.8
        },
        "anti_hallucination": {
          "rubric": "The response does not invent details about Gate E or CAM_09 beyond what was provided in context.",
          "threshold": 0.8
        }
      },
      "deterministic_checks": {
        "max_word_count": 80,
        "max_response_time_ms": 10000,
        "success_must_be_true": true
      }
    },
