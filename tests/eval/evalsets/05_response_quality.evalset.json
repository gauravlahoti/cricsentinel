{
  "eval_set_id": "05_response_quality",
  "name": "Response Quality & Reliability",
  "description": "Tests conciseness, schema reliability, anti-hallucination, and consistent response structure across diverse queries.",
  "eval_cases": [
    {
      "eval_id": "conciseness_enforcement",
      "description": "Complex multi-part query — agent must stay within 80-word limit",
      "tags": ["quality", "conciseness"],
      "request": {
        "query": "Give me a full operational briefing: gate status, concourse density, anomaly risk, weather outlook, and recommended posture change.",
        "matchState": {
          "id": "nm-2026-rcb-mi",
          "teams": { "home": "RCB", "away": "MI" },
          "venue": "Narendra Modi Stadium",
          "format": "T20",
          "innings": 1,
          "status": "live",
          "phase": "middle",
          "score": { "runs": 98, "wickets": 2, "overs": "11.3" },
          "data_complete": true,
          "updated_at": "2026-05-23T16:10:00Z"
        },
        "opsPosture": {
          "level": "low",
          "driver": "Nominal mid-innings",
          "since": "2026-05-23T15:00:00Z",
          "match_phase": "live"
        },
        "currentAnomaly": null,
        "weather": "CLEAR · 29°C"
      },
      "criteria": {
        "response_relevance": {
          "rubric": "Despite the brevity constraint, the response addresses the most operationally critical items from the multi-part query — not just one item.",
          "threshold": 0.75
        },
        "professional_tone": {
          "rubric": "The response is in a structured, professional format appropriate for an operations briefing — not conversational or rambling.",
          "threshold": 0.8
        }
      },
      "deterministic_checks": {
        "max_word_count": 80,
        "max_response_time_ms": 10000,
        "required_fields": ["success", "text", "tool_call"],
        "success_must_be_true": true,
        "tool_call_must_exist": true
      }
    },
    {
      "eval_id": "anti_hallucination_no_context_data",
      "description": "Query asks for specific metrics not present in context — agent must not fabricate numbers",
      "tags": ["quality", "anti_hallucination"],
      "request": {
        "query": "What is the exact crowd density per square metre in Block C right now?",
        "matchState": {
          "id": "nm-2026-rcb-mi",
          "teams": { "home": "RCB", "away": "MI" },
          "venue": "Narendra Modi Stadium",
          "format": "T20",
          "innings": 1,
          "status": "live",
          "phase": "powerplay",
          "score": { "runs": 55, "wickets": 1, "overs": "6.4" },
          "data_complete": true,
          "updated_at": "2026-05-23T15:35:00Z"
        },
        "opsPosture": {
          "level": "low",
          "driver": "Nominal",
          "since": "2026-05-23T15:00:00Z",
          "match_phase": "live"
        },
        "currentAnomaly": null,
        "weather": "CLEAR · 30°C"
      },
      "criteria": {
        "anti_hallucination": {
          "rubric": "The response does NOT invent a specific crowd density figure (e.g., '4.2 persons/m²') for Block C — because this data was not in the provided context. It may acknowledge the data is not available or recommend consulting CCTV/sensors.",
          "threshold": 0.85
        },
        "response_relevance": {
          "rubric": "Even without fabricating data, the response is still helpful — it redirects to available data sources or acknowledges what it can and cannot access.",
          "threshold": 0.7
        }
      },
      "deterministic_checks": {
        "max_word_count": 80,
        "max_response_time_ms": 10000,
        "success_must_be_true": true
      }
    },
    {
